# Django Core
DJANGO_SECRET_KEY=your-secret-key-here-make-it-long-and-random
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — matches auth-db service in docker-compose.yml
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

# Email — Gmail SMTP
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here

# Frontend URL — used in email verification links
FRONTEND_URL=http://localhost:3000

# CORS — comma separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
