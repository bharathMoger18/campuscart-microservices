# Django
SECRET_KEY=your-secret-key-here-must-match-auth-service
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,notification-service

# Database
DB_NAME=notification_db
DB_USER=notification_user
DB_PASSWORD=notification_pass
DB_HOST=localhost
DB_PORT=5436

# Redis (Channel Layer)
REDIS_URL=redis://localhost:6380/0

# Auth Service
AUTH_SERVICE_URL=http://localhost:8001

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# VAPID (Push Notifications)
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@yourdomain.com
